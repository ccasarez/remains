@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix shapes: <http://example.com/foaf-profile/shapes#> .

# Every Person must have exactly one non-empty name
shapes:PersonShape a sh:NodeShape ;
    sh:targetClass foaf:Person ;
    sh:property [
        sh:path foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Person must have exactly one non-empty name." ;
    ] .

# Every Organization must have exactly one non-empty name
shapes:OrganizationShape a sh:NodeShape ;
    sh:targetClass foaf:Organization ;
    sh:property [
        sh:path foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Organization must have exactly one non-empty name." ;
    ] .

# Every Project must have exactly one non-empty title
shapes:ProjectShape a sh:NodeShape ;
    sh:targetClass foaf:Project ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Project must have exactly one non-empty title." ;
    ] .

# Every Document must have a title and at least one maker
shapes:DocumentShape a sh:NodeShape ;
    sh:targetClass foaf:Document ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Document must have a title." ;
    ] ;
    sh:property [
        sh:path foaf:maker ;
        sh:minCount 1 ;
        sh:class foaf:Agent ;
        sh:message "Document must have at least one maker." ;
    ] .
