@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix data: <http://example.com/data/> .

# === Invalid data: demonstrates various validation failures ===

# BUG 1: Typed as abstract dcat:Resource (should be Dataset, Distribution, or DataService)
data:mystery-resource a dcat:Resource ;
    dct:title "Some Resource" ;
    prov:wasDerivedFrom <http://example.com/sources/test.html> .

# BUG 2: Dataset missing required description and publisher (SHACL violations)
data:bare-dataset a dcat:Dataset ;
    dct:title "Dataset With No Details" ;
    prov:wasDerivedFrom <http://example.com/sources/test.html> .

# BUG 3: Distribution missing required mediaType (SHACL violation)
data:untyped-dist a dcat:Distribution ;
    dct:title "Mystery Download" ;
    dcat:downloadURL "https://example.com/data.bin" ;
    prov:wasDerivedFrom <http://example.com/sources/test.html> .

# BUG 4: DataService missing required endpointURL (SHACL violation)
data:broken-service a dcat:DataService ;
    dct:title "API With No Endpoint" ;
    prov:wasDerivedFrom <http://example.com/sources/test.html> .

# BUG 5: Organization with empty name (SHACL minLength violation)
data:nameless-org a foaf:Organization ;
    foaf:name "" ;
    prov:wasDerivedFrom <http://example.com/sources/test.html> .

# BUG 6: Unknown type not in schema
data:dashboard-x a dcat:Dashboard ;
    dct:title "Mystery Dashboard" ;
    prov:wasDerivedFrom <http://example.com/sources/test.html> .
