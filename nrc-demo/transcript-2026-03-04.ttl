# === Agenda Item 1: North Anna appeal ===

nrc:item-1 a nrc:AgendaItem ;
    nrc:itemNumber "1"^^xsd:integer ;
    nrc:title "North Anna Power Station subsequent license renewal appeal" ;
    nrc:concerns nrc:doc-secy-24-0095 ;
    nrc:involvesFacility nrc:facility-north-anna ;
    nrc:involvesOrganization nrc:org-virginia-electric, nrc:org-beyond-nuclear, nrc:org-sierra-club ;
    nrc:resultedIn nrc:decision-1 ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

nrc:decision-1 a nrc:Decision ;
    nrc:outcome "Approved Memorandum and Order affirming LBP-24-7" ;
    nrc:description "Affirmed the Atomic Safety and Licensing Board's decision denying Beyond Nuclear and Sierra Club's hearing request in the subsequent license renewal proceeding for North Anna Power Station." ;
    nrc:voteResult "5-0 unanimous" ;
    nrc:votedBy nrc:person-nieh, nrc:person-wright, nrc:person-crowell, nrc:person-marzano, nrc:person-weaver ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

# === Agenda Item 2: Turkey Point petition ===

nrc:item-2 a nrc:AgendaItem ;
    nrc:itemNumber "2"^^xsd:integer ;
    nrc:title "Turkey Point subsequent license renewal petition for review" ;
    nrc:concerns nrc:doc-secy-25-0011 ;
    nrc:involvesFacility nrc:facility-turkey-point ;
    nrc:involvesOrganization nrc:org-fpl, nrc:org-miami-waterkeeper ;
    nrc:resultedIn nrc:decision-2 ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

nrc:decision-2 a nrc:Decision ;
    nrc:outcome "Denied Miami Waterkeeper's petition for review" ;
    nrc:description "Denied petition for review of LBP-24-8, which dismissed contentions and terminated the proceeding related to Turkey Point subsequent license renewal. Chairman Nieh did not participate." ;
    nrc:voteResult "4-0 (Chairman Nieh recused)" ;
    nrc:votedBy nrc:person-wright, nrc:person-crowell, nrc:person-marzano, nrc:person-weaver ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

# === Agenda Item 3: Global Laser Enrichment ===

nrc:item-3 a nrc:AgendaItem ;
    nrc:itemNumber "3"^^xsd:integer ;
    nrc:title "Global Laser Enrichment Paducah facility notice and order" ;
    nrc:concerns nrc:doc-secy-25-0079 ;
    nrc:involvesFacility nrc:facility-paducah ;
    nrc:involvesOrganization nrc:org-gle ;
    nrc:resultedIn nrc:decision-3 ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

nrc:decision-3 a nrc:Decision ;
    nrc:outcome "Approved Federal Register notice and Order" ;
    nrc:description "Approved notice of hearing, guidance on several issues, and milestone schedule for GLE's application to construct and operate a uranium enrichment facility using laser-based isotope separation technology." ;
    nrc:voteResult "5-0 unanimous" ;
    nrc:votedBy nrc:person-nieh, nrc:person-wright, nrc:person-crowell, nrc:person-marzano, nrc:person-weaver ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

# === Agenda Item 4: FOIA final rule ===

nrc:item-4 a nrc:AgendaItem ;
    nrc:itemNumber "4"^^xsd:integer ;
    nrc:title "FOIA implementing regulations final rule" ;
    nrc:concerns nrc:doc-secy-25-0100 ;
    nrc:resultedIn nrc:decision-4 ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

nrc:decision-4 a nrc:Decision ;
    nrc:outcome "Approved publication and implementation of final rule" ;
    nrc:description "Approved final rule amending 10 CFR FOIA implementing regulations. Certified under Regulatory Flexibility Act that rule will not have significant economic impact on small entities." ;
    nrc:voteResult "5-0 unanimous" ;
    nrc:votedBy nrc:person-nieh, nrc:person-wright, nrc:person-crowell, nrc:person-marzano, nrc:person-weaver ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

# === Agenda Item 5: Palisades/Holtec motion ===

nrc:item-5 a nrc:AgendaItem ;
    nrc:itemNumber "5"^^xsd:integer ;
    nrc:title "Palisades motion to dismiss contention and terminate proceeding" ;
    nrc:concerns nrc:doc-secy-25-0101 ;
    nrc:involvesFacility nrc:facility-palisades ;
    nrc:involvesOrganization nrc:org-entergy, nrc:org-holtec ;
    nrc:resultedIn nrc:decision-5 ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

nrc:decision-5 a nrc:Decision ;
    nrc:outcome "Denied motion to dismiss; proceeding remains in abeyance" ;
    nrc:description "Denied Applicants' motion to dismiss pending contention as moot and to terminate the proceeding. Continues to hold proceeding in abeyance per CLI-25-2. Chairman Nieh offered additional views." ;
    nrc:voteResult "5-0 unanimous" ;
    nrc:votedBy nrc:person-nieh, nrc:person-wright, nrc:person-crowell, nrc:person-marzano, nrc:person-weaver ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

# === Agenda Item 6: TerraPower Kemmerer construction permit ===

nrc:item-6 a nrc:AgendaItem ;
    nrc:itemNumber "6"^^xsd:integer ;
    nrc:title "Kemmerer Power Station construction permit mandatory hearing" ;
    nrc:concerns nrc:doc-secy-26-0018 ;
    nrc:involvesFacility nrc:facility-kemmerer ;
    nrc:involvesOrganization nrc:org-us-sfr, nrc:org-terrapower ;
    nrc:resultedIn nrc:decision-6 ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .

nrc:decision-6 a nrc:Decision ;
    nrc:outcome "Authorized issuance of construction permit" ;
    nrc:description "Approved Memorandum and Order authorizing issuance of construction permit for Kemmerer Power Station Unit 1, a Natrium advanced reactor. Chairman Nieh noted this is a historic step forward for advanced nuclear energy in the United States." ;
    nrc:voteResult "5-0 unanimous" ;
    nrc:votedBy nrc:person-nieh, nrc:person-wright, nrc:person-crowell, nrc:person-marzano, nrc:person-weaver ;
    prov:wasDerivedFrom <https://www.nrc.gov/docs/ML2606/ML26069A020.pdf> .
